# API
# Bearer token sent as `Authorization: Bearer <key>` to /v1/*. Pick a long
# random string before exposing the API anywhere outside localhost.
API_KEY=change-me
API_BIND_HOST=0.0.0.0
API_BIND_PORT=8000

# Postgres
# In compose mode the api container overrides this to `postgres:5432`.
DATABASE_URL=postgresql+psycopg://pliny:pliny@localhost:5432/pliny

# Neo4j
# In compose mode the api container overrides NEO4J_URI to `neo4j:7687`.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# RustFS / S3-compatible (unused until step 10)
# In compose mode the api container overrides RUSTFS_ENDPOINT to `rustfs:9000`.
RUSTFS_ENDPOINT=http://localhost:9000
RUSTFS_ACCESS_KEY=
RUSTFS_SECRET_KEY=
RUSTFS_BUCKET=pliny

# Local-disk blob store (used in dev/test). Compose mounts a named volume at
# /var/lib/pliny/blob and overrides BLOB_ROOT to point there.
BLOB_ROOT=./.blob-dev

# OpenAI
# Get an API key from https://platform.openai.com/api-keys. Without it the
# pipeline will fail at the summarize/embed/entities/extract-image stages.
OPENAI_API_KEY=
# Per-minute request and token rate limits. The LLM wrapper enforces a token
# bucket so concurrent workers don't bust your account-level limits. Match
# these to your tier (see https://platform.openai.com/account/limits).
OPENAI_RPM=60
OPENAI_TPM=90000
# Hard daily spend cap in USD. The wrapper estimates each call's cost from
# token counts and the pinned price. When usd_spent >= cap, calls raise
# CostCapExceeded and the worker reschedules past midnight UTC. In-flight
# calls finish. Reset is implicit — a new row appears for the next UTC day.
OPENAI_DAILY_USD_CAP=20

# Embeddings
# Active embedding model. Bumping this name kicks off the migration described
# in user_stories.md S16 — new rows land in embeddings_1536 with the new
# model_name; old rows stay until you flip search to the new index.
CURRENT_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_MODEL_VERSION=1

# Telegram
# Token from @BotFather (https://t.me/BotFather → /newbot). Looks like
# `123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11`. Keep it secret — anyone with
# it can post as your bot.
TELEGRAM_BOT_TOKEN=
# Comma-separated numeric Telegram user IDs allowed to send the bot ingest
# messages. Find your ID by messaging @userinfobot. Empty list = bot rejects
# every message (since this is single-user, leaving it empty effectively
# disables the bot).
TELEGRAM_ALLOWED_USER_IDS=
# Where the bot reaches the Pliny API. In host mode this is localhost. In
# compose mode the bot container overrides this to `http://api:8000`.
PLINY_API_BASE_URL=http://localhost:8000

# Workers
FAST_WORKER_CONCURRENCY=4
SLOW_WORKER_CONCURRENCY=2
# Sweeper resets jobs stuck in 'running' longer than this many seconds.
STAGE_TIMEOUT_SECONDS=900

# Frontend dev (Vite default origin). Comma-separated list; empty disables
# CORS. Only needed when the SPA calls the API cross-origin (i.e. without
# the Vite dev proxy). In compose mode the frontend nginx reverse-proxies
# same-origin so this stays empty.
CORS_ALLOWED_ORIGINS=http://localhost:5173
