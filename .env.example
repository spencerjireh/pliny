# API
API_KEY=change-me
API_BIND_HOST=0.0.0.0
API_BIND_PORT=8000

# Postgres
DATABASE_URL=postgresql+psycopg://pliny:pliny@localhost:5432/pliny

# Neo4j (unused until step 8)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# RustFS / S3-compatible (unused until step 10)
RUSTFS_ENDPOINT=http://localhost:9000
RUSTFS_ACCESS_KEY=
RUSTFS_SECRET_KEY=
RUSTFS_BUCKET=pliny

# Local-disk blob store (used in dev/test)
BLOB_ROOT=./.blob-dev

# OpenAI
OPENAI_API_KEY=
OPENAI_RPM=60
OPENAI_TPM=90000
OPENAI_DAILY_USD_CAP=20

# Embeddings
CURRENT_EMBEDDING_MODEL=text-embedding-3-small

# Telegram (unused until step 11)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=

# Workers
FAST_WORKER_CONCURRENCY=4
SLOW_WORKER_CONCURRENCY=2
STAGE_TIMEOUT_SECONDS=900
